# Supabase Configuration
# Get these values from your Supabase project dashboard at https://supabase.com/dashboard

# Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous (public) key - safe to use in client-side code
SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key - NEVER expose in client-side code, use only on server
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional: Direct Postgres connection string for Drizzle ORM
# Format: postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# Note: Use Transaction mode (port 6543) for serverless compatibility
# Get this from: Project Settings > Database > Connection string > Transaction
DATABASE_URL=postgresql://postgres.PROJECT_REF:DATABASE_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
