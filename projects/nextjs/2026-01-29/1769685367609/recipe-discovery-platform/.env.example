# Database Configuration
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
DATABASE_URL="postgresql://user:password@localhost:5432/recipe_discovery"

# Example for local PostgreSQL:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/recipe_discovery"

# Example for Vercel Postgres:
# DATABASE_URL="postgres://default:xxx@xxx-pooler.region.aws.neon.tech:5432/verceldb?sslmode=require"

# Example for Supabase:
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.xxx.supabase.co:5432/postgres"

# Example for Railway:
# DATABASE_URL="postgresql://postgres:xxx@containers-us-west-xxx.railway.app:5432/railway"

# Authentication Configuration
# Generate a random secret: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# Auth URL (for production, set to your actual domain)
NEXTAUTH_URL="http://localhost:3000"
