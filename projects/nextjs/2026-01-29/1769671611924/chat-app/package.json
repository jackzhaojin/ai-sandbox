    "@types/bcryptjs": "^2.4.6",
    "ai": "^6.0.59",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.6.2",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "next": "^15.2.0",
    "next-auth": "^5.0.0-beta.30",
    "prisma": "^7.3.0",
    "react": "^19.2.4",
