# ============================================
# B2B Postal Checkout - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your actual values
# DO NOT commit .env.local with real credentials to version control

# --------------------------------------------
# Supabase Configuration (Required)
# --------------------------------------------
# Get these from your Supabase project dashboard:
# https://supabase.com/dashboard/project/_/settings/api

# Client-side (public) - exposed to browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side (private) - only accessible in API routes
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --------------------------------------------
# Database Connection (Required for seed scripts)
# --------------------------------------------
# Use the connection string from Supabase Dashboard > Database > Connection string
# Format: postgresql://postgres.[project-ref]:[password]@aws-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-1-us-east-2.pooler.supabase.com:6543/postgres

# --------------------------------------------
# Application Configuration (Optional)
# --------------------------------------------
# Node environment - set to 'production' for production builds
NODE_ENV=development

# Application port (default: 3000)
PORT=3000

# --------------------------------------------
# Feature Flags (Optional)
# --------------------------------------------
# Enable mock mode for testing without database
NEXT_PUBLIC_MOCK_MODE=false

# Enable debug logging in development
DEBUG=false

# --------------------------------------------
# Cloud Supabase Setup Notes
# --------------------------------------------
# 1. Create a new Supabase project at https://supabase.com
# 2. Go to Project Settings > API to get your credentials
# 3. Apply the database schema from migrations/001_create_postal_v2_schema.sql
# 4. Run seed data: npm run db:seed
# 5. Verify setup: npm run db:verify
#
# Schema: postal_v2 (isolated from public schema)
# Tables: organizations, users, addresses, carriers, service_types,
#         shipments, quotes, pickup_slots, shipment_events, etc.
#
# RLS Policies: Enabled on all tables for security
# PostGIS: Enable the PostGIS extension for geolocation features
